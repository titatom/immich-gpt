# ── Immich connection ─────────────────────────────────────────────────────────
# You can also set these after launch via Settings → Immich Connection in the UI.
IMMICH_URL=http://192.168.1.x:2283
IMMICH_API_KEY=your-immich-api-key

# ── AI provider ───────────────────────────────────────────────────────────────
# OpenAI (leave blank to configure provider in the UI instead)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require a Bearer token on all API endpoints.
# When AUTH_ENABLED=false the API is open to anyone who can reach this host.
#
# SECRET_KEY: if left blank or as the placeholder, a secure random key is
# auto-generated at first startup and written back to this file. Copy the
# generated value from .env and use it as your Bearer token.
AUTH_ENABLED=false
# SECRET_KEY=  ← leave blank to auto-generate, or paste your own token here

# ── Worker ────────────────────────────────────────────────────────────────────
# Number of background job threads (single-container mode).
# Ignored when REDIS_URL is set.
WORKER_CONCURRENCY=2

# ── Redis (full-stack mode only) ──────────────────────────────────────────────
# Leave blank (or omit) for single-container deployments.
# Set when using  docker compose --profile full up
REDIS_URL=
