# =============================================================================
# Immich GPT — environment configuration
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# ── Volume / path ─────────────────────────────────────────────────────────────
# Host directory mounted to /data inside the container.
# All persistent data lives here: SQLite DB, settings, job history, user accounts.
# Back this directory up regularly.
#
# Unraid default — points to standard appdata share:
DATA_DIR=/mnt/user/appdata/immich-gpt
#
# Linux / macOS example:
# DATA_DIR=/opt/immich-gpt/data

# ── Admin account bootstrap ───────────────────────────────────────────────────
# On first startup, if no users exist, Immich GPT creates an admin account
# using these credentials. Set ADMIN_EMAIL and ADMIN_PASSWORD before first start.
# Leave ADMIN_USERNAME blank to reuse ADMIN_EMAIL as the login username.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=

# ── Session security ──────────────────────────────────────────────────────────
# Cryptographic key used to sign session cookies.
# Change this to any long random string before going to production.
# Example: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Set SESSION_COOKIE_SECURE=true when running behind HTTPS (recommended for
# internet-exposed deployments).  Leave false for LAN-only HTTP setups.
SESSION_COOKIE_SECURE=false

# ── Immich connection ─────────────────────────────────────────────────────────
# You can also set these after launch via Settings → Immich Connection in the UI.
IMMICH_URL=http://192.168.1.x:2283
IMMICH_API_KEY=your-immich-api-key

# ── AI provider ───────────────────────────────────────────────────────────────
# OpenAI (leave blank to configure provider in the UI instead)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── App ───────────────────────────────────────────────────────────────────────
# Host port that maps to container port 8000.
APP_PORT=8000
# Optional: override the image tag used by docker-compose.yml.
IMMICH_GPT_IMAGE=ghcr.io/titatom/immich-gpt:latest

# ── Admin account bootstrap ───────────────────────────────────────────────────
# On first startup, if no users exist, Immich GPT creates an admin account
# using these credentials.
# Blank / missing ADMIN_EMAIL or ADMIN_PASSWORD values skip bootstrap entirely.
# Leave ADMIN_USERNAME blank to reuse ADMIN_EMAIL as the login username.
# Set ADMIN_SKIP_BOOTSTRAP=true to suppress auto-creation entirely.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=
# ADMIN_SKIP_BOOTSTRAP=false

# ── Session security ──────────────────────────────────────────────────────────
# Set SESSION_COOKIE_SECURE=true when running behind HTTPS (recommended for
# internet-exposed deployments).  Leave false for LAN-only HTTP setups.
SESSION_COOKIE_SECURE=false

# ── Worker ────────────────────────────────────────────────────────────────────
# Number of background job threads (single-container mode).
# Ignored when REDIS_URL is set.
WORKER_CONCURRENCY=2

# ── Redis (optional, power-user mode) ────────────────────────────────────────
# Leave blank for single-container deployments — jobs run in-process.
# Set to enable RQ distributed workers (useful for 1000+ assets/day or
# running a separate worker container):
#   REDIS_URL=redis://localhost:6379/0
REDIS_URL=
