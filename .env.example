# =============================================================================
# Immich GPT — environment configuration
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   docker compose up -d
#
# On first visit, a web setup wizard will create the initial admin account.
# =============================================================================

# ── Volume / path ─────────────────────────────────────────────────────────────
# Host directory mounted to /data inside the container.
# All persistent data lives here: SQLite DB, settings, job history, user accounts.
# Back this directory up regularly.
#
# Unraid default — points to standard appdata share:
DATA_DIR=/mnt/user/appdata/immich-gpt
#
# Linux / macOS example:
# DATA_DIR=/opt/immich-gpt/data

# Optional: host directory for persistent rotating log files.
# Leave unset to discard logs when the container is removed.
# LOG_DIR=/mnt/user/appdata/immich-gpt/logs

# ── Session security ──────────────────────────────────────────────────────────
# Cryptographic key used to sign session cookies.
# Leave blank to let the container auto-generate a key on first boot
# (saved to /data/.secret_key so it survives restarts and upgrades).
# For production deployments, set your own strong key:
#   SECRET_KEY=$(openssl rand -hex 32)
SECRET_KEY=

# Set SESSION_COOKIE_SECURE=true when running behind HTTPS (recommended for
# internet-exposed deployments).  Leave false for LAN-only HTTP setups.
SESSION_COOKIE_SECURE=false

# ── Immich connection ─────────────────────────────────────────────────────────
# You can also set these after launch via Settings → Immich Connection in the UI.
IMMICH_URL=http://192.168.1.x:2283
IMMICH_API_KEY=your-immich-api-key

# ── AI provider ───────────────────────────────────────────────────────────────
# OpenAI (leave blank to configure provider in the UI instead)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── App ───────────────────────────────────────────────────────────────────────
# Host port that maps to container port 8000.
APP_PORT=8000
# Optional: override the image tag used by docker-compose.yml.
IMMICH_GPT_IMAGE=ghcr.io/titatom/immich-gpt:latest

# ── Worker ────────────────────────────────────────────────────────────────────
# Number of background job threads (built-in thread pool, no Redis needed).
# Increase if you have many assets and a fast AI provider.
WORKER_CONCURRENCY=2

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Leave blank — jobs run in-process via the built-in thread pool (recommended).
# Set this only if you already run Redis on your home lab and want to dispatch
# jobs through RQ instead:
#   REDIS_URL=redis://192.168.1.x:6379/0
REDIS_URL=

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls log verbosity. INFO is suitable for normal use.
# Valid values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
