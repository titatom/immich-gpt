# ── Immich connection ─────────────────────────────────────────────────────────
# You can also set these later in Settings -> Immich Connection after signing in.
IMMICH_URL=http://192.168.1.x:2283
IMMICH_API_KEY=your-immich-api-key

# ── AI provider ───────────────────────────────────────────────────────────────
# Optional. Leave blank if you plan to configure a provider in the UI instead.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# Required on a fresh database so you can sign in for the first time.
# These values are only used when no users exist yet.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_USERNAME=admin

# ── App / compose ─────────────────────────────────────────────────────────────
# Host port published by docker compose.
APP_PORT=8000

# ── Storage / local backend runtime ───────────────────────────────────────────
# Used by local backend runs and custom deployments.
# The provided docker compose file injects its own /data-backed SQLite path.
DATABASE_URL=sqlite:///./data/immich_gpt.db

# ── Worker execution ──────────────────────────────────────────────────────────
# Background job threads for single-container mode or local backend runs.
# Ignored when REDIS_URL is set.
WORKER_CONCURRENCY=2

# ── Redis / RQ (optional) ─────────────────────────────────────────────────────
# Leave blank for the default single-container mode.
# For custom multi-process setups, use: redis://redis:6379/0
REDIS_URL=

# ── Extra API bearer-token gate (optional) ────────────────────────────────────
# This adds an Authorization: Bearer <SECRET_KEY> requirement to API requests.
# It does not replace the normal UI login/session flow.
AUTH_ENABLED=false
SECRET_KEY=change-me-to-a-long-random-secret
