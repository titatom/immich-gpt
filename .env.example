# ── Immich connection ─────────────────────────────────────────────────────────
# You can also set these after launch via Settings → Immich Connection in the UI.
IMMICH_URL=http://192.168.1.x:2283
IMMICH_API_KEY=your-immich-api-key

# ── AI provider ───────────────────────────────────────────────────────────────
# OpenAI (leave blank to configure provider in the UI instead)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8000
# Optional: override the image tag used by docker-compose.yml.
IMMICH_GPT_IMAGE=ghcr.io/titatom/immich-gpt:latest

# ── Admin account bootstrap ───────────────────────────────────────────────────
# On first startup, if no users exist, Immich GPT creates an admin account
# using these credentials.  The admin is forced to change the password on
# first login.  Leave both blank to skip auto-creation.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login
ADMIN_USERNAME=admin

# ── Session security ──────────────────────────────────────────────────────────
# Set SESSION_COOKIE_SECURE=true when running behind HTTPS (recommended for
# internet-exposed deployments).  Leave false for LAN-only HTTP setups.
SESSION_COOKIE_SECURE=false

# ── Worker ────────────────────────────────────────────────────────────────────
# Number of background job threads (single-container mode).
# Ignored when REDIS_URL is set.
WORKER_CONCURRENCY=2

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Leave blank to use the built-in thread-pool worker (recommended).
# Set to redis://host:6379/0 to dispatch jobs through an existing Redis instance.
REDIS_URL=
